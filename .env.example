# -----------------------------------------------------------------------------
# AWS settings for the runnable examples in Chapters 4-6.
#
# Copy this file to `.env` (in the same directory) and fill in your values:
#
#     cp .env.example .env
#
# The examples pick these up automatically — no code edits needed. Values you
# already have in your shell environment always take precedence over this file.
# -----------------------------------------------------------------------------

# --- Credentials ---
# If you've already run `aws configure`, leave these commented out and the AWS
# CLI will use your configured profile. Otherwise, paste your keys here.
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# --- Account / region ---
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# --- MicroVM resource ARNs ---
# The IAM role a MicroVM assumes at runtime (execution role).
MICROVM_EXECUTION_ROLE_ARN=arn:aws:iam::123456789012:role/MicroVMExecutionRole

# The IAM role used to build MicroVM images.
MICROVM_BUILD_ROLE_ARN=arn:aws:iam::123456789012:role/service-role/MicroVMBuildRole

# The ARN of a MicroVM image you've built (see Chapter 4).
MICROVM_IMAGE_ARN=arn:aws:lambda:us-east-1:123456789012:microvm-image:my-sandbox

# S3 URI of the zipped Dockerfile + app that Chapter 4 builds an image from.
MICROVM_CODE_ARTIFACT_URI=s3://your-bucket/app.zip
